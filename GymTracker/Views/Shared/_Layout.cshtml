<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - GymTracker</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/GymTracker.styles.css" asp-append-version="true" />

    <style>
        /* Global Dark Theme applied to the whole app */
        body {
            background-color: #121212 !important;
            color: #e0e0e0 !important;
        }

        /* Navbar specific styling */
        .navbar-custom {
            background-color: #1e1e1e;
            border-bottom: 2px solid #d32f2f !important;
        }

        .nav-link-custom {
            color: #e0e0e0 !important;
            transition: color 0.2s;
        }

            .nav-link-custom:hover {
                color: #d32f2f !important;
            }

        .text-gym-red {
            color: #d32f2f !important;
        }

        /* Footer styling */
        .footer-custom {
            background-color: #1e1e1e;
            border-top: 1px solid #333 !important;
        }
    </style>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-toggleable-sm navbar-dark navbar-custom box-shadow mb-3">
            <div class="container-fluid">
                <div class="navbar-brand fw-bold">
                    <span class="text-gym-red">GYM</span>TRACKER
                </div>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse" aria-controls="navbarSupportedContent"
                        aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                    <ul class="navbar-nav flex-grow-1">
                        

                        @if (User.Identity.IsAuthenticated)
                        {
                            <li class="nav-item">
                                <a class="nav-link nav-link-custom fw-bold" asp-controller="Workout" asp-action="Index">My Workouts</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link nav-link-custom fw-bold" asp-controller="Workout" asp-action="History">Workout History</a>
                            </li>
                        }

                        
                    </ul>

                    @if (User.Identity.IsAuthenticated)
                    {
                        <form asp-controller="Account" asp-action="Logout" method="post" class="d-flex align-items-center">
                            <span class="navbar-text text-light me-3">Hello, @User.Identity.Name!</span>
                            <button type="submit" class="btn btn-outline-danger btn-sm fw-bold">Log Out</button>
                        </form>
                    }
                    else
                    {
                        <ul class="navbar-nav">
                            <li class="nav-item">
                                <a class="nav-link nav-link-custom" asp-controller="Account" asp-action="Login">Login</a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link nav-link-custom" asp-controller="Account" asp-action="Register">Register</a>
                            </li>
                        </ul>
                    }
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="footer-custom footer text-light py-3">
        <div class="container text-center">
            &copy; 2026 - GymTracker - <a class="text-gym-red text-decoration-none" asp-area="" asp-controller="Home" asp-action="Privacy">Privacy</a>
        </div>
    </footer>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>