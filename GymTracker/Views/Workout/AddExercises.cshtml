@model GymTracker.ViewModels.AddExerciseViewModel

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">

            <div class="card shadow-lg rounded-3" style="background-color: #1e1e1e; border: 1px solid #333;">
                <div class="card-body p-4 p-md-5">

                    <h2 class="fw-bold mb-2 text-light">
                        <span style="color: #d32f2f;">|</span> Step 2: Add Exercises
                    </h2>
                    <p style="color: #a0a0a0; font-size: 0.95rem;">Select an exercise and enter your target sets.</p>

                    <form asp-action="AddExercises" method="post" class="mt-4">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3 fw-bold"></div>

                        <input type="hidden" asp-for="WorkoutTemplateId" />

                        <div class="mb-4">
                            <label asp-for="SelectedExerciseId" class="form-label text-light fw-bold">Choose Exercise</label>
                            <select asp-for="SelectedExerciseId" asp-items="Model.AvailableExercises" class="form-select form-select-lg"
                                    style="background-color: #2a2a2a; color: #ffffff; border: 1px solid #444;">
                                <option value="" style="color: #a0a0a0;">-- Select an Exercise --</option>
                            </select>
                            <span asp-validation-for="SelectedExerciseId" class="text-danger mt-1 d-block fw-bold"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="TargetSets" class="form-label text-light fw-bold">Target Sets</label>
                            <input asp-for="TargetSets" class="form-control form-control-lg" type="number" min="1" max="20"
                                   style="background-color: #2a2a2a; color: #ffffff; border: 1px solid #444;" />
                            <span asp-validation-for="TargetSets" class="text-danger mt-1 d-block fw-bold"></span>
                        </div>

                        <div class="d-flex gap-3 mt-4">
                            <button type="submit" class="btn btn-lg fw-bold shadow-sm flex-grow-1"
                                    style="background-color: #d32f2f; color: white; border: none;">
                                + Add Exercise
                            </button>

                            <a asp-action="Index" class="btn btn-outline-light btn-lg fw-bold px-4">
                                Finish & Save
                            </a>
                        </div>
                    </form>

                </div>
            </div>

        </div>
    </div>
</div>