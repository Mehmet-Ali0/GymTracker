@model GymTracker.ViewModels.AddExerciseViewModel

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <h2>Step 2: Add Exercises</h2>
            <p class="text-muted">Select an exercise and enter your target sets.</p>

            <form asp-action="AddExercises" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                <input type="hidden" asp-for="WorkoutTemplateId" />

                <div class="mb-3">
                    <label asp-for="SelectedExerciseId" class="form-label">Choose Exercise</label>
                    <select asp-for="SelectedExerciseId" asp-items="Model.AvailableExercises" class="form-select">
                        <option value="">-- Select an Exercise --</option>
                    </select>
                    <span asp-validation-for="SelectedExerciseId" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="TargetSets" class="form-label"></label>
                    <input asp-for="TargetSets" class="form-control" type="number" min="1" max="20" />
                    <span asp-validation-for="TargetSets" class="text-danger"></span>
                </div>

                <button type="submit" class="btn btn-primary">Add Exercise</button>

                <a asp-action="Index" class="btn btn-secondary ms-2">Finish & Save Workout</a>
            </form>
        </div>
    </div>
</div>