@model IEnumerable<GymTracker.Models.WorkoutTemplate>

<style>
    /* Temporarily forcing the body dark so you can see the effect */
    body {
        background-color: #121212 !important;
        color: #e0e0e0 !important;
    }

    /* Custom Gym Theme Classes */
    .gym-card {
        background-color: #1e1e1e;
        border: 1px solid #2a2a2a;
        transition: transform 0.2s ease, border-color 0.2s ease;
    }

        .gym-card:hover {
            transform: translateY(-4px);
            border-color: #d32f2f; /* Red accent on hover */
            box-shadow: 0 8px 15px rgba(211, 47, 47, 0.1) !important;
        }

    .btn-gym-red {
        background-color: #d32f2f;
        color: white;
        border: none;
        font-weight: 600;
        transition: background-color 0.2s;
    }

        .btn-gym-red:hover {
            background-color: #b71c1c;
            color: white;
        }

    .text-gym-red {
        color: #d32f2f !important;
    }

    .dark-alert {
        background-color: #1e1e1e;
        border: none;
        border-left: 4px solid #d32f2f;
        color: #e0e0e0;
    }

    .border-dark-custom {
        border-color: #333 !important;
    }
</style>

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4 border-bottom border-dark-custom pb-3">
        <h2 class="fw-bold mb-0">
            <span class="text-gym-red">|</span> My Workouts
        </h2>
        <div>
            <a asp-action="Stats" class="btn btn-outline-light me-2 fw-bold">My Stats</a>
            <a asp-action="Create" class="btn btn-gym-red shadow-sm">+ Create New Workout</a>
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="alert dark-alert shadow-sm">
            <i class="text-gym-red fw-bold">Alert:</i> You haven't created any workouts yet. Click the button above to get started.
        </div>
    }
    else
    {
        <div class="row">
            @foreach (var workout in Model)
            {
                <div class="col-md-4 mb-4">
                    <div class="card gym-card shadow-sm h-100 text-light rounded-3">
                        <div class="card-body d-flex flex-column">
                            <h5 class="card-title fw-bold text-uppercase tracking-wide mb-1">@workout.Name</h5>
                            <p class="text-muted small mb-4">Template ID: @workout.Id</p>

                            <div class="mt-auto pt-3 border-top border-dark-custom d-flex justify-content-between align-items-center">
                                <form asp-action="StartSession" asp-route-templateId="@workout.Id" method="post" class="m-0">
                                    <button type="submit" class="btn btn-gym-red btn-sm px-3 py-2">Start Session</button>
                                </form>
                                <a asp-action="Edit" asp-route-id="@workout.Id" class="btn btn-outline-secondary btn-sm">Edit</a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>