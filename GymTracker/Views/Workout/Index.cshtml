@model IEnumerable<GymTracker.Models.WorkoutTemplate>

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>My Workouts</h2>
        <a asp-action="Create" class="btn btn-primary">+ Create New Workout</a>
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-info">
            You haven't created any workouts yet. Click the button above to get started!
        </div>
    }
    else
    {
        <div class="row">
            @foreach (var workout in Model)
            {
                <div class="col-md-4 mb-4">
                    <div class="card shadow-sm h-100">
                        <div class="card-body">
                            <h5 class="card-title fw-bold">@workout.Name</h5>
                            <p class="text-muted small">Template ID: @workout.Id</p>

                            <div class="mt-3">
                                <form asp-action="StartSession" asp-route-templateId="@workout.Id" method="post" style="display:inline;">
                                    <button type="submit" class="btn btn-outline-success btn-sm">Start Session</button>
                                </form>
                                <a asp-action="Edit" asp-route-id="@workout.Id" class="btn btn-outline-secondary btn-sm">Edit</a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>