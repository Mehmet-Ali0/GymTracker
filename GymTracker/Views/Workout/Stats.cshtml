@model GymTracker.ViewModels.StatsViewModel

@{
    ViewData["Title"] = "Workout Stats";
}

<div class="container mt-4">
    <h2 class="fw-bold mb-4 text-light">
        <span style="color: #d32f2f;">|</span> My Stats
    </h2>

    <div class="row">
        <div class="col-md-6 mb-4">
            <div class="card shadow-lg rounded-3 h-100" style="background-color: #1e1e1e; border: 1px solid #333;">
                <div class="card-body p-4">
                    <h5 class="card-title fw-bold text-light mb-3">This Week: Sets per Muscle</h5>
                    <div style="position: relative; height: 300px; width: 100%;">
                        <canvas id="volumeChart"></canvas>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-6 mb-4">
            <div class="card shadow-lg rounded-3 h-100" style="background-color: #1e1e1e; border: 1px solid #333;">
                <div class="card-body p-4">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h5 class="card-title fw-bold text-light mb-0">Volume Progress</h5>
                        <select id="exerciseSelect" class="form-select form-select-sm w-50"
                                style="background-color: #2a2a2a; color: #ffffff; border: 1px solid #444;">
                            <option value="" disabled selected style="color: #a0a0a0;">Select an exercise...</option>
                            @foreach (var ex in Model.AvailableExercises)
                            {
                                <option value="@ex.Id">@ex.Name</option>
                            }
                        </select>
                    </div>
                    <div style="position: relative; height: 300px; width: 100%;">
                        <canvas id="progressChart"></canvas>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <script>
        document.addEventListener("DOMContentLoaded", function () {

            
            const darkThemeScales = {
                x: {
                    ticks: { color: '#a0a0a0' },
                    grid: { color: '#333333' }
                },
                y: {
                    beginAtZero: true,
                    ticks: { color: '#a0a0a0' },
                    grid: { color: '#333333' }
                }
            };

            const darkThemePlugins = {
                legend: {
                    labels: { color: '#e0e0e0' }
                }
            };

            
            const volumeDataRaw = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.MuscleVolumeData));
            const volumeLabels = volumeDataRaw.map(d => d.MuscleGroup);
            const volumeData = volumeDataRaw.map(d => d.TotalSets);

            const ctxVolume = document.getElementById('volumeChart').getContext('2d');
            new Chart(ctxVolume, {
                type: 'bar',
                data: {
                    labels: volumeLabels,
                    datasets: [{
                        label: 'Total Sets',
                        data: volumeData,
                        backgroundColor: 'rgba(211, 47, 47, 0.8)', 
                        borderColor: '#d32f2f',
                        borderWidth: 1,
                        borderRadius: 4
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: darkThemePlugins,
                    scales: { ...darkThemeScales, y: { ...darkThemeScales.y, suggestedMax: 10 } }
                }
            });

            
            let progressChartInstance = null;
            const ctxProgress = document.getElementById('progressChart').getContext('2d');
            const exerciseSelect = document.getElementById('exerciseSelect');

            function loadProgressChart(exerciseId) {
                fetch(`/Workout/GetExerciseProgressData?exerciseId=${exerciseId}`)
                    .then(response => response.json())
                    .then(data => {
                        const dates = data.map(d => d.dateString);
                        const volumes = data.map(d => d.totalVolume);

                        if (progressChartInstance) {
                            progressChartInstance.destroy();
                        }

                        progressChartInstance = new Chart(ctxProgress, {
                            type: 'line',
                            data: {
                                labels: dates,
                                datasets: [{
                                    label: 'Total Volume (kg)',
                                    data: volumes,
                                    borderColor: '#d32f2f', 
                                    backgroundColor: 'rgba(211, 47, 47, 0.15)', 
                                    fill: true,
                                    tension: 0.3, 
                                    pointBackgroundColor: '#1e1e1e',
                                    pointBorderColor: '#d32f2f',
                                    pointBorderWidth: 2,
                                    pointRadius: 4
                                }]
                            },
                            options: {
                                responsive: true,
                                maintainAspectRatio: false,
                                plugins: darkThemePlugins,
                                scales: darkThemeScales
                            }
                        });
                    })
                    .catch(error => console.error('Error fetching progress data:', error));
            }

            
            exerciseSelect.addEventListener('change', function () {
                const selectedId = this.value;
                if (selectedId) {
                    loadProgressChart(selectedId);
                }
            });

            if (exerciseSelect.options.length > 1) {
                exerciseSelect.selectedIndex = 1;
                loadProgressChart(exerciseSelect.value);
            }
        });
    </script>
}