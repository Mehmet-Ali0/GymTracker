@model GymTracker.ViewModels.StatsViewModel

@{
    ViewData["Title"] = "Workout Stats";
}

<div class="container mt-4">
    <h2 class="mb-4">My Stats</h2>

    <div class="row">
        <div class="col-md-6 mb-4">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <h5 class="card-title">Last 7 Days: Sets per Muscle Group</h5>
                    <canvas id="volumeChart"></canvas>
                </div>
            </div>
        </div>

        <div class="col-md-6 mb-4">
            <div class="card shadow-sm h-100">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h5 class="card-title mb-0">Volume Chart</h5>
                        <select id="exerciseSelect" class="form-select w-50">
                            <option value="" disabled selected>Select an exercise...</option>
                            @foreach (var ex in Model.AvailableExercises)
                            {
                                <option value="@ex.Id">@ex.Name</option>
                            }
                        </select>
                    </div>
                    <canvas id="progressChart"></canvas>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <script>
        document.addEventListener("DOMContentLoaded", function () {

            
            const volumeDataRaw = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.MuscleVolumeData));

            const volumeLabels = volumeDataRaw.map(d => d.MuscleGroup);
            const volumeData = volumeDataRaw.map(d => d.TotalSets);

            const ctxVolume = document.getElementById('volumeChart').getContext('2d');
            new Chart(ctxVolume, {
                type: 'bar',
                data: {
                    labels: volumeLabels,
                    datasets: [{
                        label: 'Total Sets',
                        data: volumeData,
                        backgroundColor: 'rgba(54, 162, 235, 0.6)',
                        borderColor: 'rgba(54, 162, 235, 1)',
                        borderWidth: 1
                    }]
                },
                options: {
                    responsive: true,
                    scales: { y: { beginAtZero: true, suggestedMax: 10 } }
                }
            });

            
            let progressChartInstance = null;
            const ctxProgress = document.getElementById('progressChart').getContext('2d');
            const exerciseSelect = document.getElementById('exerciseSelect');

            
            function loadProgressChart(exerciseId) {
                fetch(`/Workout/GetExerciseProgressData?exerciseId=${exerciseId}`)
                    .then(response => response.json())
                    .then(data => {
                        const dates = data.map(d => d.dateString);
                        const volumes = data.map(d => d.totalVolume);

                        
                        if (progressChartInstance) {
                            progressChartInstance.destroy();
                        }

                        progressChartInstance = new Chart(ctxProgress, {
                            type: 'line',
                            data: {
                                labels: dates,
                                        datasets: [{
                                         label: 'Total Volume (kg)',
                                         data: volumes,
                                         borderColor: 'rgba(32, 201, 151, 1)',
                                         backgroundColor: 'rgba(32, 201, 151, 0.2)',
                                         fill: true,
                                         tension: 0.1
                                        }]
                            },
                            options: {
                                responsive: true,
                                scales: { y: { beginAtZero: true } }
                            }
                        });
                    })
                    .catch(error => console.error('Error fetching progress data:', error));
            }

            
            exerciseSelect.addEventListener('change', function () {
                const selectedId = this.value;
                if (selectedId) {
                    loadProgressChart(selectedId);
                }
            });

           
            if (exerciseSelect.options.length > 1) {
                exerciseSelect.selectedIndex = 1;
                loadProgressChart(exerciseSelect.value);
            }
        });
    </script>
}