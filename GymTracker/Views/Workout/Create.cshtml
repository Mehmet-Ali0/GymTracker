@model GymTracker.ViewModels.CreateWorkoutViewModel

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <h2>Step 1: Name Your Workout</h2>
            <p class="text-muted">Example: "Monday Push Day" or "Heavy Leg Day"</p>

            <form asp-action="Create" method="post">
                <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                <div class="mb-3">
                    <label asp-for="Name" class="form-label"></label>
                    <input asp-for="Name" class="form-control" placeholder="Enter name..." />
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>

                <button type="submit" class="btn btn-primary">Continue to Add Exercises</button>
            </form>
        </div>
    </div>
</div>